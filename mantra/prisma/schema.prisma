generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  banner        String?
  password      String?
  bio           String?
  university    String?
  department    String?
  level         String?
  website       String?
  location      String?
  isVerified    Boolean   @default(false)
  role          Role      @default(STUDENT)
  bannedAt      DateTime?
  banReason     String?
  aiCredits     Int       @default(50)
  agentName     String?
  themeConfig   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stacks        Stack[]         @relation("StackOwner")
  contributions Contribution[]
  stars         StackStar[]
  forks         StackFork[]
  bookmarks     Bookmark[]
  sessions      Session[]
  accounts      Account[]
  discussions   Discussion[]
  comments      Comment[]
  followers     Follow[]        @relation("Following")
  following     Follow[]        @relation("Follower")
  notifications Notification[]
  apiKeys       ApiKey[]
  progress      LearningProgress[]
  taggedIn      StackTaggedUser[]  @relation("TaggedUser")
  tagging       StackTaggedUser[]  @relation("Tagger")
  purchases     Purchase[]
  bankAccount   BankAccount?
  quizAttempts  QuizAttempt[]
  creditTxns    CreditTransaction[]
  stackFlows    StackFlow[]
  agentConversations AgentConversation[]
  communityMessages  CommunityMessage[]
  customAgents       CustomAgent[]       @relation("AgentOwner")
  agentSubscriptions AgentSubscription[] @relation("AgentSubscriber")
  knowledgeHubsOwned KnowledgeHub[]      @relation("HubCreator")
  knowledgeHubMemberships KnowledgeHubMember[]
  agentProjects      AgentProject[]
  agentWorkspaceItems AgentWorkspaceItem[]
  agentScheduleSessions AgentScheduleSession[]
  articles           Article[]           @relation("ArticleAuthor")
  articlePurchases   ArticlePurchase[]
  customAgentConversations CustomAgentConversation[]
  whatsAppAgentCodes       WhatsAppAgentCode[]
  adminOfCommunities Community[]      @relation("CommunityAdmin")
  communityMemberships CommunityMember[]
  communityStacksAdded CommunityStack[] @relation("CommunityStackContributor")
  communityInvitesReceived CommunityInvite[] @relation("CommunityInviteReceiver")
  communityInvitesSent     CommunityInvite[] @relation("CommunityInviteSender")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Stack {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  courseCode  String?
  university  String?
  department  String?
  semester    String?
  language    String   @default("PDF")
  isPaid      Boolean  @default(false)
  price       Float?
  duration    String?
  isPublic    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  isArchived  Boolean  @default(false)
  readme      String?
  banner      String?
  profile     String?
  views        Int      @default(0)
  ownerId      String
  forkedFromId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User             @relation("StackOwner", fields: [ownerId], references: [id])
  forkedFrom    Stack?           @relation("ForkOrigin", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forkedCopies  Stack[]          @relation("ForkOrigin")
  tags          StackTag[]
  modules       Module[]
  editions      Edition[]
  stars         StackStar[]
  forks         StackFork[]
  bookmarks     Bookmark[]
  discussions   Discussion[]
  contributions Contribution[]
  progress      LearningProgress[]
  files         StackFile[]
  taggedUsers   StackTaggedUser[]
  purchases     Purchase[]
  quizzes       Quiz[]
  mtContents    MtContent[]
  flowItems     StackFlowItem[]
  communityStacks CommunityStack[]
  knowledgeHubs KnowledgeHubStack[]

  @@map("stacks")
}

model StackFile {
  id          String   @id @default(cuid())
  stackId     String
  moduleId    String?
  name        String
  url         String
  rawPath     String?
  size        Int      @default(0)
  mimeType    String   @default("application/octet-stream")
  mtContentId String?
  createdAt   DateTime @default(now())
  stack       Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@map("stack_files")
}

model Edition {
  id          String   @id @default(cuid())
  stackId     String
  version     String
  changelog   String?
  snapshot    Json
  editorId    String
  createdAt   DateTime @default(now())

  stack       Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  mtContent   MtContent[]

  @@map("editions")
}

model MtContent {
  id            String   @id @default(cuid())
  editionId     String
  stackId       String
  rawContent    String
  sections      Json
  concepts      Json
  summary       String?
  references    Json
  searchIndex   String
  fileName      String?
  fileType      String?
  encryptedData String?
  encryptedIv   String?
  authTag       String?
  isEncrypted   Boolean  @default(false)
  createdAt     DateTime @default(now())

  edition       Edition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  stack         Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@map("mt_content")
}

model Module {
  id       String  @id @default(cuid())
  title    String
  type     String  @default("lecture")
  files    Int     @default(0)
  duration String?
  order    Int     @default(0)
  stackId  String
  stack    Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@map("modules")
}

model Tag {
  id     String     @id @default(cuid())
  name   String     @unique
  stacks StackTag[]

  @@map("tags")
}

model StackTag {
  stackId String
  tagId   String
  stack   Stack  @relation(fields: [stackId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([stackId, tagId])
  @@map("stack_tags")
}

model StackStar {
  userId    String
  stackId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@id([userId, stackId])
  @@map("stack_stars")
}

model StackFork {
  id        String   @id @default(cuid())
  userId    String
  stackId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@map("stack_forks")
}

model Bookmark {
  userId    String
  stackId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@id([userId, stackId])
  @@map("bookmarks")
}

model Contribution {
  id        String             @id @default(cuid())
  userId    String
  stackId   String
  message   String
  status    ContributionStatus @default(PENDING)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
  stack     Stack              @relation(fields: [stackId], references: [id])

  @@map("contributions")
}

model Discussion {
  id        String    @id @default(cuid())
  title     String
  body      String
  userId    String
  stackId   String
  resolved  Boolean   @default(false)
  isPinned  Boolean   @default(false)
  type      String    @default("discussion")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  stack     Stack     @relation(fields: [stackId], references: [id])
  comments  Comment[]

  @@map("discussions")
}

model Comment {
  id           String     @id @default(cuid())
  body         String
  userId       String
  discussionId String
  isAccepted   Boolean    @default(false)
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  key       String   @unique
  lastUsed  DateTime?
  requests  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model LearningProgress {
  id         String   @id @default(cuid())
  userId     String
  stackId    String
  moduleId   String?
  position   Int      @default(0)
  completed  Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stack      Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@unique([userId, stackId])
  @@map("learning_progress")
}

model Quiz {
  id          String         @id @default(cuid())
  stackId     String
  title       String
  description String?
  createdAt   DateTime       @default(now())
  stack       Stack          @relation(fields: [stackId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id           String @id @default(cuid())
  quizId       String
  question     String
  options      Json
  correctIndex Int
  explanation  String?
  order        Int    @default(0)
  quiz         Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int
  total     Int
  answers   Json
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String?
  paystackRef String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

enum Role {
  STUDENT
  PROFESSOR
  ADMIN
}

enum ContributionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  STAR
  FORK
  CONTRIBUTION
  COMMENT
  FOLLOW
  SYSTEM
  QUIZ
  CREDIT
  COMMUNITY_INVITE
  COMMUNITY_JOIN
}

enum CommunityRole {
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model StackTaggedUser {
  id        String   @id @default(cuid())
  stackId   String
  userId    String
  taggedBy  String
  createdAt DateTime @default(now())
  stack     Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)
  user      User     @relation("TaggedUser", fields: [userId], references: [id], onDelete: Cascade)
  tagger    User     @relation("Tagger", fields: [taggedBy], references: [id], onDelete: Cascade)

  @@unique([stackId, userId])
  @@map("stack_tagged_users")
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  stackId      String
  amount       Float
  currency     String   @default("NGN")
  paystackRef  String?  @unique
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stack        Stack    @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@unique([userId, stackId])
  @@map("purchases")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("email_verifications")
}

model StackFlow {
  id          String          @id @default(cuid())
  userId      String
  name        String
  description String?
  emoji       String          @default("📚")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       StackFlowItem[]

  @@map("stack_flows")
}

model StackFlowItem {
  id      String    @id @default(cuid())
  flowId  String
  stackId String
  addedAt DateTime  @default(now())
  flow    StackFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stack   Stack     @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@unique([flowId, stackId])
  @@map("stack_flow_items")
}

model Community {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String?
  banner      String?
  profile     String?
  rules       String?
  adminId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  admin       User              @relation("CommunityAdmin", fields: [adminId], references: [id])
  members     CommunityMember[]
  stacks      CommunityStack[]
  invites     CommunityInvite[]
  messages    CommunityMessage[]

  @@map("communities")
}

model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("community_members")
}

model CommunityStack {
  id          String    @id @default(cuid())
  communityId String
  stackId     String
  addedBy     String
  addedAt     DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  stack       Stack     @relation(fields: [stackId], references: [id], onDelete: Cascade)
  contributor User      @relation("CommunityStackContributor", fields: [addedBy], references: [id])

  @@unique([communityId, stackId])
  @@map("community_stacks")
}

model CommunityInvite {
  id            String       @id @default(cuid())
  communityId   String
  invitedUserId String
  invitedBy     String
  status        InviteStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  community     Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  invitedUser   User         @relation("CommunityInviteReceiver", fields: [invitedUserId], references: [id], onDelete: Cascade)
  inviter       User         @relation("CommunityInviteSender", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([communityId, invitedUserId])
  @@map("community_invites")
}

model GatewayConfig {
  id            String    @id @default(cuid())
  webhookUrl    String
  sharedSecret  String
  waNumber      String
  isActive      Boolean   @default(false)
  connectedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("gateway_config")
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  accountNumber String
  bankCode      String
  bankName      String
  accountName   String
  recipientCode String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model CommunityMessage {
  id          String    @id @default(cuid())
  communityId String
  userId      String
  content     String
  createdAt   DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("community_messages")
}

// ─── Mentra Agents ────────────────────────────────────────────────────────────

model CustomAgent {
  id            String   @id @default(cuid())
  ownerId       String
  name          String
  subject       String
  level         String   @default("Undergraduate")
  domain        String   @default("education")
  tone          String   @default("patient")
  personality   String?
  avatarUrl     String?
  isPublished   Boolean  @default(false)
  price         Float    @default(0)
  isPaid        Boolean  @default(false)
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner          User                     @relation("AgentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  knowledgeFiles AgentKnowledgeFile[]
  conversations  CustomAgentConversation[]
  subscriptions  AgentSubscription[]
  listing        AgentListing?
  whatsAppCodes  WhatsAppAgentCode[]

  @@map("custom_agents")
}

model AgentKnowledgeFile {
  id        String      @id @default(cuid())
  agentId   String
  name      String
  url       String
  size      Int         @default(0)
  mimeType  String      @default("application/octet-stream")
  content   String?
  createdAt DateTime    @default(now())
  agent     CustomAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_knowledge_files")
}

model CustomAgentConversation {
  id        String               @id @default(cuid())
  agentId   String
  userId    String
  title     String               @default("New Chat")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  agent     CustomAgent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CustomAgentMessage[]

  @@map("custom_agent_conversations")
}

model CustomAgentMessage {
  id             String                  @id @default(cuid())
  conversationId String
  role           String
  content        String
  verb           String?
  thinkMs        Int?
  imageUrl       String?
  createdAt      DateTime                @default(now())
  conversation   CustomAgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("custom_agent_messages")
}

model AgentListing {
  id          String      @id @default(cuid())
  agentId     String      @unique
  title       String
  description String?
  price       Float       @default(0)
  isPaid      Boolean     @default(false)
  isActive    Boolean     @default(true)
  coverImage  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  agent       CustomAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  subscriptions AgentSubscription[]

  @@map("agent_listings")
}

model AgentSubscription {
  id        String       @id @default(cuid())
  userId    String
  agentId   String
  listingId String
  createdAt DateTime     @default(now())
  user      User         @relation("AgentSubscriber", fields: [userId], references: [id], onDelete: Cascade)
  agent     CustomAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  listing   AgentListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@map("agent_subscriptions")
}

// ─── Knowledge Hubs (integrated with Stacks) ──────────────────────────────────

model KnowledgeHub {
  id          String               @id @default(cuid())
  slug        String               @unique
  title       String
  description String?
  domain      String               @default("general")
  isPublic    Boolean              @default(true)
  accessCost  Int                  @default(0)
  coverImage  String?
  creatorId   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  creator     User                 @relation("HubCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members     KnowledgeHubMember[]
  stacks      KnowledgeHubStack[]

  @@map("knowledge_hubs")
}

model KnowledgeHubMember {
  id        String       @id @default(cuid())
  hubId     String
  userId    String
  role      String       @default("member")
  joinedAt  DateTime     @default(now())
  hub       KnowledgeHub @relation(fields: [hubId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hubId, userId])
  @@map("knowledge_hub_members")
}

model KnowledgeHubStack {
  id      String       @id @default(cuid())
  hubId   String
  stackId String
  addedAt DateTime     @default(now())
  hub     KnowledgeHub @relation(fields: [hubId], references: [id], onDelete: Cascade)
  stack   Stack        @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@unique([hubId, stackId])
  @@map("knowledge_hub_stacks")
}

// ─── Agent Projects & Workspace ───────────────────────────────────────────────

model AgentProject {
  id          String            @id @default(cuid())
  userId      String
  title       String
  subject     String?
  deadline    DateTime?
  status      String            @default("todo")
  priority    String            @default("medium")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       AgentProjectTask[]

  @@map("agent_projects")
}

model AgentProjectTask {
  id        String       @id @default(cuid())
  projectId String
  label     String
  done      Boolean      @default(false)
  order     Int          @default(0)
  project   AgentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("agent_project_tasks")
}

model AgentWorkspaceItem {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  type      String   @default("note")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_workspace_items")
}

model AgentScheduleSession {
  id          String   @id @default(cuid())
  userId      String
  title       String
  subject     String?
  date        DateTime
  duration    Int      @default(60)
  completed   Boolean  @default(false)
  notes       String?
  stackId     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_schedule_sessions")
}

// ─── Articles ─────────────────────────────────────────────────────────────────

model Article {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  summary     String?
  authorId    String
  price       Float            @default(0)
  isPaid      Boolean          @default(false)
  isPublished Boolean          @default(false)
  coverImage  String?
  views       Int              @default(0)
  tags        String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  author      User             @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  editions    ArticleEdition[]
  purchases   ArticlePurchase[]

  @@map("articles")
}

model ArticleEdition {
  id          String             @id @default(cuid())
  articleId   String
  number      Int
  label       String
  content     String
  connectors  ArticleConnector[]
  publishedAt DateTime           @default(now())
  article     Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, number])
  @@map("article_editions")
}

model ArticleConnector {
  id           String         @id @default(cuid())
  editionId    String
  textAnchorId String
  imageNodeId  String
  edition      ArticleEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@map("article_connectors")
}

model ArticlePurchase {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  amount    Float    @default(0)
  paidAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("article_purchases")
}

// ─── WhatsApp Agent Codes ─────────────────────────────────────────────────────

model WhatsAppAgentCode {
  id          String    @id @default(cuid())
  code        String    @unique
  agentId     String
  userId      String
  used        Boolean   @default(false)
  phoneNumber String?
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  agent       CustomAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("whatsapp_agent_codes")
}

// ─── Platform agent conversations (existing, unchanged) ───────────────────────

model AgentConversation {
  id        String         @id @default(cuid())
  userId    String
  title     String         @default("New Chat")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AgentMessage[]

  @@map("agent_conversations")
}

model AgentMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           String
  content        String
  imageUrl       String?
  createdAt      DateTime          @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("agent_messages")
}
